# SleepCare Platform Environment Configuration Template
# Copy this file to '.env' and populate with VM / Server endpoints before deployment.
# DO NOT commit the '.env' file containing real credentials to the repository.

# URL of the Backend API Server VM (e.g. Render, or your Backend VM IP)
VITE_API_URL=https://cpap-backend-v3.onrender.com

# URL of the Dedicated Video Storage Server VM (Lyon 2 Server)
VITE_VIDEO_URL=https://cpap-backend-v3.onrender.com
